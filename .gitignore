.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.idea/
.vscode/

# Модели: в git держим только основную обученную модель.
модели/*.pt
!модели/best.pt

# Черновики из редактора. Их лучше не отправлять напарникам случайно.
Untitled-*.py

# Видео обычно тяжелые. В репозиторий кладем код, а видео передаем отдельно
# или добавляем выборочно, если оно точно нужно для защиты.
видео/тестовые_видео/*
видео/кадры/*
видео/разметка/*
!видео/тестовые_видео/.gitkeep
!видео/кадры/.gitkeep
!видео/разметка/.gitkeep

